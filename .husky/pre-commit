#!/bin/sh
husky_sh="$(dirname "$0")/_/husky.sh"
if [ -f "$husky_sh" ]; then
  . "$husky_sh"
fi

# Check branch name
local_branch="$(git rev-parse --abbrev-ref HEAD)"
valid_branch_regex="^(main|master|develop|(feature|bugfix|hotfix|release|chore|feat|fix|docs|refactor|test)/[a-zA-Z0-9_\-]+)$"

if [[ ! $local_branch =~ $valid_branch_regex ]]; then
    echo "❌ Error: Branch name '$local_branch' does not follow Git Flow conventions."
    echo "   Must start with: feature/, bugfix/, hotfix/, release/, chore/, feat/, fix/, docs/"
    exit 1
fi

# Run lint-staged if installed
if npx --no -- lint-staged --version >/dev/null 2>&1; then
  npx --no -- lint-staged
fi
